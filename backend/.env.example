# Environment Variables Reference
# Copy to .env and fill in actual values

# Database
DATABASE_URL=postgresql+asyncpg://propvision:propvision_secret@postgres:5432/propvision

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Pollinations (Video Walkthrough) — https://gen.pollinations.ai
POLLINATIONS_API_KEY=your-pollinations-key-here

# Mapbox (used by frontend, referenced in backend for tile URL generation)
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token-here

# Google Places API
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# AWS S3-compatible Object Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=propvision-models
S3_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com

# API Security
API_SECRET_KEY=your-random-secret-key-for-signing-minimum-32-chars

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-characters-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://propvision.ai

# Application
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
